# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# PostgreSQL Configuration (for local development)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=aeonrfp

# Authentication
SESSION_SECRET=your-session-secret-key-here

# OpenAI API (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Service (Resend)
RESEND_API_KEY=re_your-resend-api-key-here

# OAuth Integrations
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
SLACK_CLIENT_ID=your-slack-oauth-client-id
SLACK_CLIENT_SECRET=your-slack-oauth-client-secret

# Optional: Slack Bot Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=your-slack-channel-id

# Optional: SendGrid (alternative to Resend)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Optional: Microsoft OAuth (coming soon)
MICROSOFT_CLIENT_ID=your-microsoft-oauth-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-oauth-client-secret

# Deployment Configuration
REPLIT_DOMAINS=https://your-project-name.replit.app
NODE_ENV=development